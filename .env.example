# ============================================================
# Morning-Brief Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- REQUIRED ---
ANTHROPIC_API_KEY=sk-ant-...
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop   # 16-char App Password from myaccount.google.com/apppasswords
SMS_TO_ADDRESS=16127074194@tmomail.net   # T-Mobile: @tmomail.net | AT&T: @txt.att.net | Verizon: @vtext.com

# --- FEATURE FLAGS (true/false) ---
ENABLE_WEATHER=true
ENABLE_NEWS=true
ENABLE_MARKET=true
ENABLE_CALENDAR=false                  # Requires Google OAuth setup (see below)
ENABLE_CUSTOM=false
ENABLE_SPORTS=true                     # ESPN sports headlines (top + local by city)

# --- WEATHER ---
WEATHER_LOCATION=New York,US
WEATHER_PROVIDER=wttr                  # "wttr" (no key) or "openweathermap"
OPENWEATHERMAP_API_KEY=                # Only needed if WEATHER_PROVIDER=openweathermap

# --- NEWS (comma-separated RSS feed URLs) ---
NEWS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml
NEWS_MAX_ITEMS_PER_FEED=5

# --- MARKET DATA (all via yfinance, no API key needed) ---
ENABLE_QQQM_HOLDINGS=true
QQQM_TOP_N=5                           # How many top holdings to show (1-10)
ENABLE_CRYPTO=true                     # BTC and ETH prices
STOCK_WATCHLIST=AAPL,MSFT,NVDA        # Your personal tickers (comma-separated)

# --- GOOGLE CALENDAR (optional) ---
# 1. Create a project at console.cloud.google.com
# 2. Enable Google Calendar API
# 3. Create OAuth 2.0 credentials (Desktop app)
# 4. Download the JSON and save to: credentials/google_oauth_client.json
# 5. Run the app once interactively to authorize; token.json will be created automatically
GOOGLE_CREDENTIALS_FILE=credentials/google_oauth_client.json
GOOGLE_TOKEN_FILE=credentials/token.json

# --- CUSTOM URLS (optional, comma-separated) ---
CUSTOM_URLS=

# --- CLAUDE TUNING ---
ANTHROPIC_MODEL=claude-haiku-4-5      # claude-haiku-4-5 (fast/cheap) or claude-sonnet-4-6 (smarter)
SMS_TARGET_CHARS=280                   # 160=single SMS, 280=2-part, 1600=10-part max
BRIEFING_STYLE=concise                 # "concise" or "detailed"
RECIPIENT_NAME=                        # Your name (personalizes the briefing, optional)
